# ─── SUPABASE ───────────────────────────────────────────────────────
# Sem estas duas variáveis o app roda em MODO DEMONSTRAÇÃO (dados de exemplo).
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OCR DE NF — cascata de provedores ──────────────────────────────
# Ordem (custo): Gemini (grátis) → Claude (pago) → Groq → OpenRouter → OCR.space → Tesseract (local).
# Cada um é tentado se tiver chave; em erro/limite, cai para o próximo.
# Sem nenhuma chave, o app usa OCR local no navegador (Tesseract.js, grátis).
#
# Claude (Anthropic) — pago, alta confiabilidade:
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6
# Google Gemini (free tier — https://aistudio.google.com/apikey):
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
# Groq (free tier, visão — https://console.groq.com/keys):
GROQ_API_KEY=gsk_...
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OpenRouter (free tier — https://openrouter.ai/keys):
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free
# OCR.space (free, lê PDF e imagem — https://ocr.space/ocrapi):
OCRSPACE_API_KEY=...

# ─── ANÁLISE DE MERCADO (busca na web) ───────────────────────────────
# Perplexity Sonar (preferido — busca em tempo real com citações):
#   chave em https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar
# Fallback: se não houver Perplexity, usa Claude (ANTHROPIC_API_KEY) com web search;
# sem nenhum, mostra atalhos de busca (Google Notícias, JusBrasil, SEMAD, etc.).

# ─── GOOGLE MAPS ─────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...   # mesma key, exposta para Maps Embed/JS

# ─── N8N ─────────────────────────────────────────────────────────────
N8N_BASE_URL=https://n8n.seudominio.com.br   # ou http://45.39.210.115:5678
N8N_API_KEY=chave-de-autenticacao-n8n
N8N_WEBHOOK_NF=https://n8n.seudominio.com.br/webhook/nf-extract
N8N_WEBHOOK_WHATSAPP=https://n8n.seudominio.com.br/webhook/whatsapp-parse
N8N_WEBHOOK_CFEM=https://n8n.seudominio.com.br/webhook/cfem-sync
# Exposto ao cliente para upload direto do WhatsApp pelo navegador:
NEXT_PUBLIC_N8N_WEBHOOK_WHATSAPP=https://n8n.seudominio.com.br/webhook/whatsapp-parse

# ─── WEB PUSH NOTIFICATIONS ──────────────────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BL...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:gustavo@martinslanna.com.br

# ─── APP ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://aggregaintel.vercel.app
NEXT_PUBLIC_MBV_CNPJ=03.334.595/0001-00
NEXT_PUBLIC_MBV_RAZAO=MBV Mineracao Bela Vista Ltda
